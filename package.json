{
  "name": "assignment2-student-course-management",
  "version": "1.0.0",
  "description": "Student and course management API with PostgreSQL, Jest, SuperTest, and PM2",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:3000": "cross-env PORT=3000 node src/server.js",
    "start:4000": "cross-env PORT=4000 node src/server.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "migrate": "node scripts/migrate.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage"
  },
  "keywords": [
    "express",
    "postgresql",
    "jest",
    "supertest",
    "pm2"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "pm2": "^5.4.2",
    "supertest": "^7.1.4"
  }
}
